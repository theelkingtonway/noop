<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      NOOP is an OFFLINE WHOOP companion. It talks to the strap over BLE and stores
      everything locally (Room). The ONLY outbound network is the opt-in AI Coach
      (bring-your-own OpenAI/Anthropic key) — nothing is sent unless the user adds a
      key and asks a question. Hence the single INTERNET permission below.
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Android 12+ (API 31+) Bluetooth runtime permissions.
         neverForLocation: we do not derive physical location from BLE scans, so we
         can opt out of the location-permission requirement on API 31+. -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="s" />

    <!-- Android 8-11 (API 26-30): legacy Bluetooth perms are install-time. -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />

    <!-- Android 6-11 (API 26-30) require a location permission to perform BLE scans.
         Not requested on API 31+ thanks to neverForLocation above. -->
    <uses-permission
        android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />

    <!-- Keep the BLE link alive while collecting/offloading in the background. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"
        tools:targetApi="34" />

    <!-- Android 13+ (API 33+): the ongoing "strap connected" notification is user-dismissable and
         must be granted at runtime. Requested in MainActivity alongside the BLE permissions. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- BLE is mandatory hardware for this app. -->
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="true" />

    <!-- Health Connect (optional): read-only access to the user's own health data so it can
         be imported on-device. Nothing is uploaded. Granted at runtime, revocable any time. -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE_VARIABILITY" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_OXYGEN_SATURATION" />
    <uses-permission android:name="android.permission.health.READ_RESPIRATORY_RATE" />
    <uses-permission android:name="android.permission.health.READ_VO2_MAX" />
    <uses-permission android:name="android.permission.health.READ_WEIGHT" />
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />

    <!-- Resolve the Health Connect provider on Android 14+ (platform) and earlier (app). -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <!-- So the connection helper can detect the official WHOOP app and deep-link to its
             info screen (a strap only pairs with one app at a time). Android 11+ visibility. -->
        <package android:name="com.whoop.android" />
    </queries>

    <application
        android:name=".NoopApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NOOP"
        tools:targetApi="34">

        <activity
            android:name="com.noop.ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.NOOP">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Health Connect permissions-rationale route (Android 13 and below). -->
            <intent-filter>
                <action android:name="androidx.health.connect.action.SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Health Connect permissions-rationale route (Android 14+, platform Health Connect). -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity="com.noop.ui.MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- Keeps the WHOOP connection alive while the app is backgrounded or closed. Not exported;
             started/stopped only from within the app, gated by the "Keep connected in the
             background" Settings toggle. -->
        <service
            android:name="com.noop.ble.WhoopConnectionService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- Wrist alerts: this is what makes NOOP appear in Android's Notification Access list. The
             system binds it (guarded by BIND_NOTIFICATION_LISTENER_SERVICE) only after the user grants
             access; it reads which app posted a notification — never the content — to buzz the strap,
             gated by the Notifications-screen settings. Does nothing until access is granted + enabled. -->
        <service
            android:name="com.noop.notif.NoopNotificationListener"
            android:label="NOOP wrist alerts"
            android:exported="false"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Shares the strap log (a cache file) for bug reports. Not exported; read access is granted
             per-share via FLAG_GRANT_READ_URI_PERMISSION. Authority is applicationId-scoped so the
             full + demo flavors don't collide. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
